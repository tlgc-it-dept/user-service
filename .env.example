# -------------------------
# Application Profile
# -------------------------

# Active profile determines which configuration set to use (DEV or PROD)
ACTIVE_PROFILE=DEV

# -------------------------
# Production Database Configuration
# -------------------------

# Full JDBC connection URL for the production database
PROD_SPRING_DATASOURCE_URL=

# Production database username
PROD_SPRING_DATASOURCE_USERNAME=

# Production database password
PROD_SPRING_DATASOURCE_PASSWORD=

# Port the application runs on in production
PROD_SPRING_PORT=

# -------------------------
# Development Database Configuration
# -------------------------

# Full JDBC connection URL for the development database
DEV_SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/user_service

# Development database username
DEV_SPRING_DATASOURCE_USERNAME=root

# Development database password
DEV_SPRING_DATASOURCE_PASSWORD=

# Port the application runs on in development
DEV_SPRING_PORT=

# -------------------------
# MariaDB Credentials
# -------------------------

# Root password for the MariaDB instance (leave empty to set on first run)
MARIADB_ROOT_PASSWORD=

# Port MariaDB listens on (default: 3306)
MARIADB_PORT=3306

# -------------------------
# Thread Pool Configuration
# -------------------------

# Number of threads always kept alive in the pool
THREAD_CORE_POOL_SIZE=4

# Maximum number of threads allowed in the pool
THREAD_MAX_POOL_SIZE=50

# Number of tasks that can queue up before new threads are created
THREAD_QUEUE_CAPACITY=600

# Time (ms) idle threads above core size are kept alive before termination
THREAD_KEEP_ALIVE_MS=60000

# -------------------------
# Database Pool Configuration
# -------------------------

# Maximum number of connections in the pool
DB_MAX_POOL_SIZE=30

# Minimum number of idle connections maintained in the pool
DB_MIN_IDLE_CONNECTIONS=10

# Maximum lifetime (ms) of a connection in the pool (1 hour)
DB_CONNECTION_LIFETIME_MS=3600000

# Maximum time (ms) to wait for a connection before timing out (30 seconds)
DB_CONNECTION_TIMEOUT_MS=30000

# -------------------------
# JWT Configuration
# -------------------------

# Secret key used for signing JWT tokens (Valid Base64-encoded string) (replace with a secure value in production)
JWT.SECRET=your_jwt_secret_key

# Expiration time for JWT tokens in milliseconds (e.g., 3600000 ms = 1 hour)
JWT.EXPIRATION=3600000